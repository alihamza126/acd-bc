// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==============================
// USERS & AUTH
// ==============================

model User {
  id            Int       @id @default(autoincrement())
  username      String    @unique @db.VarChar(50)
  email         String    @unique @db.VarChar(255)
  passwordHash  String?   @map("password_hash") @db.VarChar
  status        String    @default("unverified") @db.VarChar(20)
  emailVerified Boolean   @default(false) @map("email_verified")
  avatarUrl     String?   @map("avatar_url") @db.VarChar
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamp(6)

  // Relations
  security      UserSecurity?
  authTokens    AuthToken[]
  devices       UserDevice[]
  roles         UserRole[] @relation("UserRoles")
  kyc           UserKyc[]
  listings      Listing[] @relation("SellerListings")
  dealsAsBuyer Deal[]    @relation("BuyerDeals")
  dealsAsSeller Deal[]   @relation("SellerDeals")
  dealsAsEscrow Deal[]   @relation("EscrowDeals")
  paymentsAsPayer Payment[] @relation("PayerPayments")
  paymentsAsPayee Payment[] @relation("PayeePayments")
  chatRoomParticipants ChatRoomParticipant[]
  chatMessages  ChatMessage[]
  flaggedMessages ChatMessage[] @relation("FlaggedMessages")
  deletedMessages ChatMessage[] @relation("DeletedMessages")
  chatMessageReactions ChatMessageReaction[]
  presence      UserPresence?
  notificationTokens NotificationToken[]
  notifications Notification[]
  assignedRoles UserRole[] @relation("AssignedRoles")
  dealEvents    DealEvent[]
  dealDisputesRaised DealDispute[] @relation("RaisedDisputes")
  dealDisputesAssigned DealDispute[] @relation("AssignedDisputes")
  listingComments ListingComment[]
  listingFavorites ListingFavorite[]
  kycEvents     UserKycEvent[]
  userBadges   UserBadge[]
  rating       Rating?

  @@index([status])
  @@index([deletedAt])
  @@map("users")
}

model UserSecurity {
  userId            Int       @id @map("user_id")
  twoFactorEnabled  Boolean   @default(false) @map("two_factor_enabled")
  twoFactorSecret  String?   @map("two_factor_secret") @db.VarChar
  twoFactorMethod  String?   @map("two_factor_method") @db.VarChar
  failedAttempts   Int       @default(0) @map("failed_attempts")
  lockedUntil      DateTime? @map("locked_until") @db.Timestamp(6)
  lastLoginAt      DateTime? @map("last_login_at") @db.Timestamp(6)
  lastLoginIp      String?   @map("last_login_ip") @db.VarChar
  lastUsernameChangeAt DateTime? @map("last_username_change_at") @db.Timestamp(6)
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_security")
}

model AuthToken {
  id         Int       @id @default(autoincrement())
  userId     Int       @map("user_id")
  type       String    @db.VarChar(30)
  tokenHash  String    @map("token_hash") @db.VarChar
  expiresAt  DateTime  @map("expires_at") @db.Timestamp(6)
  used       Boolean   @default(false)
  usedAt     DateTime? @map("used_at") @db.Timestamp(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId, type])
  @@map("auth_tokens")
}

model UserDevice {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  fingerprint String    @db.VarChar
  ipAddress   String?   @map("ip_address") @db.VarChar(45)
  userAgent   String?   @map("user_agent") @db.Text
  browser     String?   @db.VarChar
  os          String?   @db.VarChar
  deviceType  String?   @map("device_type") @db.VarChar
  trusted     Boolean   @default(false)
  lastSeen    DateTime  @default(now()) @map("last_seen") @db.Timestamp(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)

  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  notificationTokens NotificationToken[]

  @@unique([userId, fingerprint])
  @@index([userId])
  @@index([fingerprint])
  @@map("user_devices")
}

model UserBadge {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  badge     String    @db.VarChar(20)
  expiry    DateTime? @db.Timestamp(6)
  active    Boolean   @default(true)
  activeAt  DateTime? @map("active_at") @db.Timestamp(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, active, badge])
  @@map("user_badges")
}

model Rating {
  id       Int   @id @default(autoincrement())
  userId   Int   @unique @map("user_id")
  positive Int   @default(0)
  neutral  Int   @default(0)
  negative Int   @default(0)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ratings")
}

// ==============================
// RBAC
// ==============================

model Role {
  id          Int       @id @default(autoincrement())
  name        String    @unique @db.VarChar(50)
  description String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)

  permissions RolePermission[]
  userRoles   UserRole[]

  @@map("roles")
}

model Permission {
  id          Int       @id @default(autoincrement())
  name        String    @unique @db.VarChar(100)
  description String?   @db.Text
  groupName   String?   @map("group_name") @db.VarChar(50)

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       Int    @map("role_id")
  permissionId Int    @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId     Int       @map("user_id")
  roleId     Int       @map("role_id")
  assignedBy Int?      @map("assigned_by")
  assignedAt DateTime  @default(now()) @map("assigned_at") @db.Timestamp(6)
  expiresAt  DateTime? @map("expires_at") @db.Timestamp(6)

  user        User  @relation("UserRoles", fields: [userId], references: [id], onDelete: Cascade)
  role        Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedByUser User? @relation("AssignedRoles", fields: [assignedBy], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

// ==============================
// KYC
// ==============================

model UserKyc {
  id             Int       @id @default(autoincrement())
  userId         Int       @map("user_id")
  provider       String    @db.VarChar(50)
  status         String    @db.VarChar(20)
  level          String    @db.VarChar(20)
  country        String?   @db.VarChar(3)
  applicantId    String?   @map("applicant_id") @db.VarChar
  rejectionReason String?  @map("rejection_reason") @db.Text
  reviewedAt     DateTime? @map("reviewed_at") @db.Timestamp(6)
  expiresAt      DateTime? @map("expires_at") @db.Timestamp(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  events UserKycEvent[]

  @@index([userId, status])
  @@map("user_kyc")
}

model UserKycEvent {
  id         Int       @id @default(autoincrement())
  userKycId  Int       @map("user_kyc_id")
  actorId    Int?      @map("actor_id")
  eventType  String    @map("event_type") @db.VarChar(30)
  reason     String?   @db.Text
  rawPayload Json?     @map("raw_payload") @db.JsonB
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamp(6)

  userKyc UserKyc @relation(fields: [userKycId], references: [id], onDelete: Cascade)
  actor   User?   @relation(fields: [actorId], references: [id])

  @@index([userKycId, createdAt])
  @@map("user_kyc_events")
}

// ==============================
// LISTINGS
// ==============================

model Listing {
  id                    Int       @id @default(autoincrement())
  sellerId              Int       @map("seller_id")
  title                 String    @db.VarChar(255)
  description           String?   @db.Text
  platform              String    @db.VarChar(30)
  category              String?   @db.VarChar(50)
  link                  String?   @unique @db.VarChar
  price                 Decimal   @db.Decimal(15, 2)
  status                String    @default("draft") @db.VarChar(20)
  subscribers           BigInt?
  monthlyViews          BigInt?   @map("monthly_views")
  monthlyIncome         Decimal?  @map("monthly_income") @db.Decimal(15, 2)
  monthlyExpense        Decimal?  @map("monthly_expense") @db.Decimal(15, 2)
  monetizationAvailable Boolean   @default(false) @map("monetization_available")
  displayLink           Boolean   @default(false) @map("display_link")
  allowComments         Boolean   @default(true) @map("allow_comments")
  isFeatured            Boolean   @default(false) @map("is_featured")
  featuredExpiresAt     DateTime? @map("featured_expires_at") @db.Timestamp(6)
  viewCount             Int       @default(0) @map("view_count")
  favoriteCount         Int       @default(0) @map("favorite_count")
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt             DateTime? @map("deleted_at") @db.Timestamp(6)

  seller      User              @relation("SellerListings", fields: [sellerId], references: [id])
  media       ListingMedia[]
  comments    ListingComment[]
  favorites   ListingFavorite[]
  deals       Deal[]

  audienceCountry       String?   @db.VarChar(50)

  @@index([sellerId, status])
  @@index([status, createdAt])
  @@index([platform, category, status])
  @@map("listings")
}

model ListingMedia {
  id        Int       @id @default(autoincrement())
  listingId Int       @map("listing_id")
  fileUrl   String    @map("file_url") @db.VarChar
  fileType  String?   @map("file_type") @db.VarChar(10)
  fileSize  Int?      @map("file_size")
  sortOrder Int       @default(0) @map("sort_order")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@map("listing_media")
}

model ListingComment {
  id        Int       @id @default(autoincrement())
  listingId Int       @map("listing_id")
  userId    Int       @map("user_id")
  parentId  Int?      @map("parent_id")
  message   String    @db.Text
  isHidden  Boolean   @default(false) @map("is_hidden")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamp(6)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])
  parent  ListingComment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies ListingComment[] @relation("CommentReplies")

  @@index([listingId, createdAt])
  @@index([parentId])
  @@map("listing_comments")
}

model ListingFavorite {
  userId    Int      @map("user_id")
  listingId Int      @map("listing_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@id([userId, listingId])
  @@map("listing_favorites")
}

// ==============================
// DEALS
// ==============================

model Deal {
  id                      Int       @id @default(autoincrement())
  listingId               Int       @map("listing_id")
  buyerId                 Int       @map("buyer_id")
  sellerId                Int       @map("seller_id")
  escrowId                Int?      @map("escrow_id")
  chatRoomId              Int       @map("chat_room_id")
  type                    String    @db.VarChar(10)
  status                  String    @db.VarChar(30)
  amount                  Decimal   @db.Decimal(15, 2)
  currency                String?   @db.VarChar(10)
  buyerPaid               Boolean   @default(false) @map("buyer_paid")
  sellerApproved          Boolean   @default(false) @map("seller_approved")
  sellerConfirmedPayment  Boolean   @default(false) @map("seller_confirmed_payment")
  escrowApproved          Boolean   @default(false) @map("escrow_approved")
  paymentDeadline         DateTime? @map("payment_deadline") @db.Timestamp(6)
  rightsTransferDeadline  DateTime? @map("rights_transfer_deadline") @db.Timestamp(6)
  ownershipTransferDeadline DateTime? @map("ownership_transfer_deadline") @db.Timestamp(6)
  completedAt             DateTime? @map("completed_at") @db.Timestamp(6)
  cancelledAt             DateTime? @map("cancelled_at") @db.Timestamp(6)
  cancellationReason      String?   @map("cancellation_reason") @db.Text
  lastSocketUpdatedAt     DateTime? @map("last_socket_updated_at") @db.Timestamp(6)
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt               DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  listing      Listing       @relation(fields: [listingId], references: [id])
  buyer        User          @relation("BuyerDeals", fields: [buyerId], references: [id])
  seller       User          @relation("SellerDeals", fields: [sellerId], references: [id])
  escrow       User?         @relation("EscrowDeals", fields: [escrowId], references: [id])
  chatRoom     ChatRoom      @relation(fields: [chatRoomId], references: [id])
  events       DealEvent[]
  disputes     DealDispute[]
  payments     Payment[]

  @@index([buyerId, status])
  @@index([sellerId, status])
  @@index([listingId])
  @@index([status, createdAt])
  @@map("deals")
}

model DealEvent {
  id         Int       @id @default(autoincrement())
  dealId     Int       @map("deal_id")
  actorId    Int?      @map("actor_id")
  eventType  String    @map("event_type") @db.VarChar(50)
  fromStatus String?   @map("from_status") @db.VarChar(30)
  toStatus   String?   @map("to_status") @db.VarChar(30)
  metadata   Json?     @db.JsonB
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamp(6)

  deal  Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  actor User? @relation(fields: [actorId], references: [id])

  @@index([dealId, createdAt])
  @@map("deal_events")
}

model DealDispute {
  id          Int       @id @default(autoincrement())
  dealId      Int       @map("deal_id")
  raisedBy    Int       @map("raised_by")
  assignedTo  Int?      @map("assigned_to")
  reason      String    @db.Text
  status      String    @db.VarChar(20)
  resolution  String?   @db.Text
  resolvedAt  DateTime? @map("resolved_at") @db.Timestamp(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  deal        Deal  @relation(fields: [dealId], references: [id], onDelete: Cascade)
  raisedByUser User @relation("RaisedDisputes", fields: [raisedBy], references: [id])
  assignedToUser User? @relation("AssignedDisputes", fields: [assignedTo], references: [id])

  @@index([dealId])
  @@index([status])
  @@map("deal_disputes")
}

// ==============================
// PAYMENTS
// ==============================

model Payment {
  id            Int       @id @default(autoincrement())
  dealId        Int       @map("deal_id")
  payerId       Int       @map("payer_id")
  payeeId       Int?      @map("payee_id")
  amount        Decimal   @db.Decimal(15, 8)
  feeAmount     Decimal   @default(0) @map("fee_amount") @db.Decimal(15, 8)
  netAmount     Decimal   @map("net_amount") @db.Decimal(15, 8)
  currency      String    @db.VarChar(10)
  network       String?   @db.VarChar(30)
  paymentMethod String?   @map("payment_method") @db.VarChar(20)
  txHash        String?   @map("tx_hash") @db.VarChar
  blockNumber   BigInt?   @map("block_number")
  confirmations Int       @default(0)
  status        String    @db.VarChar(20)
  confirmedAt   DateTime? @map("confirmed_at") @db.Timestamp(6)
  refundedAt    DateTime? @map("refunded_at") @db.Timestamp(6)
  refundReason  String?   @map("refund_reason") @db.Text
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  deal  Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  payer User @relation("PayerPayments", fields: [payerId], references: [id])
  payee User? @relation("PayeePayments", fields: [payeeId], references: [id])

  @@index([dealId])
  @@index([payerId, createdAt])
  @@map("payments")
}

// ==============================
// CHAT
// ==============================

model ChatRoom {
  id                Int       @id @default(autoincrement())
  lastMessageAt     DateTime? @map("last_message_at") @db.Timestamp(6)
  lastMessagePreview String?  @map("last_message_preview") @db.VarChar(200)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  participants ChatRoomParticipant[]
  messages     ChatMessage[]
  deals        Deal[]
  notifications Notification[]

  @@index([lastMessageAt])
  @@map("chat_rooms")
}

model ChatRoomParticipant {
  id                      Int       @id @default(autoincrement())
  chatRoomId              Int       @map("chat_room_id")
  userId                  Int       @map("user_id")
  role                    String?   @db.VarChar(20)
  lastDeliveredMessageId  Int?      @map("last_delivered_message_id")
  lastReadMessageId       Int?      @map("last_read_message_id")
  isMuted                 Boolean   @default(false) @map("is_muted")
  mutedUntil              DateTime? @map("muted_until") @db.Timestamp(6)
  joinedAt                DateTime  @default(now()) @map("joined_at") @db.Timestamp(6)
  leftAt                  DateTime? @map("left_at") @db.Timestamp(6)

  chatRoom              ChatRoom    @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastDeliveredMessage  ChatMessage? @relation("DeliveredMessages", fields: [lastDeliveredMessageId], references: [id])
  lastReadMessage       ChatMessage? @relation("ReadMessages", fields: [lastReadMessageId], references: [id])

  @@unique([userId, chatRoomId])
  @@index([userId, chatRoomId])
  @@map("chat_room_participants")
}

model ChatMessage {
  id          Int       @id @default(autoincrement())
  chatRoomId  Int       @map("chat_room_id")
  senderId    Int       @map("sender_id")
  type        String?   @db.VarChar(30)
  message     String?   @db.Text
  replyToId   Int?      @map("reply_to_id")
  isFlagged   Boolean   @default(false) @map("is_flagged")
  flaggedBy   Int?      @map("flagged_by")
  deletedAt   DateTime? @map("deleted_at") @db.Timestamp(6)
  deletedBy   Int?      @map("deleted_by")
  editedAt    DateTime? @map("edited_at") @db.Timestamp(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)

  chatRoom            ChatRoom              @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  sender              User                  @relation(fields: [senderId], references: [id])
  replyTo             ChatMessage?          @relation("MessageReplies", fields: [replyToId], references: [id])
  replies             ChatMessage[]        @relation("MessageReplies")
  flaggedByUser       User?                @relation("FlaggedMessages", fields: [flaggedBy], references: [id])
  deletedByUser       User?                @relation("DeletedMessages", fields: [deletedBy], references: [id])
  attachments         ChatAttachment[]
  reactions           ChatMessageReaction[]
  deliveredTo         ChatRoomParticipant[] @relation("DeliveredMessages")
  readBy              ChatRoomParticipant[] @relation("ReadMessages")

  @@index([chatRoomId, createdAt])
  @@map("chat_messages")
}

model ChatAttachment {
  id          Int       @id @default(autoincrement())
  messageId   Int       @map("message_id")
  fileUrl     String    @map("file_url") @db.VarChar
  fileName    String?   @map("file_name") @db.VarChar
  fileType    String?   @map("file_type") @db.VarChar(20)
  fileSize    Int?      @map("file_size")
  thumbnailUrl String?  @map("thumbnail_url") @db.VarChar
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("chat_attachments")
}

model ChatMessageReaction {
  id        Int      @id @default(autoincrement())
  messageId Int      @map("message_id")
  userId    Int      @map("user_id")
  emoji     String?  @db.VarChar(10)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@map("chat_message_reactions")
}

// ==============================
// PRESENCE
// ==============================

model UserPresence {
  userId    Int      @id @map("user_id")
  status    String   @db.VarChar(10)
  lastSeen  DateTime @map("last_seen") @db.Timestamp(6)
  socketId  String?  @map("socket_id") @db.VarChar
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_presence")
}

// ==============================
// PUSH NOTIFICATIONS
// ==============================

model NotificationToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  deviceId  Int?     @map("device_id")
  token     String   @db.VarChar
  platform  String   @db.VarChar(10)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  device UserDevice? @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([userId, token])
  @@index([userId])
  @@map("notification_tokens")
}

model Notification {
  id         Int       @id @default(autoincrement())
  userId     Int       @map("user_id")
  chatRoomId Int?      @map("chat_room_id")
  type       String    @db.VarChar(50)
  title      String?   @db.VarChar(255)
  body       String?   @db.Text
  data       Json?     @db.JsonB
  readAt     DateTime? @map("read_at") @db.Timestamp(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamp(6)

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatRoom ChatRoom? @relation(fields: [chatRoomId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([chatRoomId])
  @@index([userId, readAt, createdAt])
  @@map("notifications")
}
