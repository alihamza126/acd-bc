# Database
DATABASE_URL=postgresql://user:password@localhost:5432/acd_db?schema=public

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Application
PORT=3000
APP_URL=http://localhost:3000

# Redis (optional - used for auth token/OTP cache and BullMQ queues; app runs without it using DB fallback)
REDIS_URL=redis://localhost:6379

# Basic Authentication (REQUIRED - All API requests must include Basic Auth header if these are set)
# If not set, basic auth is disabled and all requests are allowed
BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=your-secure-password

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM_NAME=Account Deal App
EMAIL_FROM_EMAIL=your-email@gmail.com

# Storage Configuration (choose one: aws or cloudinary)
STORAGE_PROVIDER=aws

# AWS S3 Configuration (if STORAGE_PROVIDER=aws)
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Cloudinary Configuration (if STORAGE_PROVIDER=cloudinary)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
